{
  "name": "sophia-hub",
  "version": "1.0.0",
  "description": "Sophia Workspace Hub - Electron transparent desktop widget",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "pack": "electron-vite build && electron-builder --dir",
    "dist": "electron-vite build && electron-builder",
    "postinstall": "electron-vite build"
  },
  "build": {
    "appId": "com.sophia.hub",
    "productName": "Sophia Hub",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*"
    ],
    "win": {
      "target": "dir",
      "icon": "resources/icon.png",
      "signAndEditExecutable": false
    }
  },
  "dependencies": {
    "framer-motion": "^11.0.0",
    "lucide-react": "^0.575.0",
    "pixelmatch": "^7.1.0",
    "pngjs": "^7.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.0",
    "@electron-toolkit/utils": "^4.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.4.0",
    "electron": "^34.0.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^3.0.0",
    "png-to-ico": "^3.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0"
  }
}
